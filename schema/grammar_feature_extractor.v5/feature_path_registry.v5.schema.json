{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deszo.local/schemas/grammar_feature_extractor/feature_path_registry.v5.schema.json",
  "title": "Feature path registry v5 meta-schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "grammar_feature_extractor.v5"
    },
    "kind": {
      "const": "feature_path_registry"
    },
    "paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "value_type": {
            "type": "string",
            "enum": [
              "boolean",
              "integer",
              "number",
              "string",
              "enum",
              "word_ref",
              "word_ref_array",
              "object",
              "array"
            ]
          },
          "enum_values": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "integer",
                "number",
                "boolean"
              ]
            },
            "uniqueItems": true
          },
          "cardinality": {
            "type": "string",
            "enum": [
              "one",
              "optional",
              "many"
            ]
          },
          "proof_relevant": {
            "type": "boolean"
          },
          "allowed_operators": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "exists",
                "equals",
                "in",
                "contains",
                "starts_with",
                "has_slot",
                "slot_equals",
                "slot_exists",
                "range",
                "not_equals"
              ]
            },
            "uniqueItems": true
          },
          "stable_since": {
            "type": "string",
            "minLength": 1
          },
          "deprecated_since": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          }
        },
        "required": [
          "path",
          "value_type",
          "cardinality",
          "proof_relevant",
          "allowed_operators",
          "stable_since"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema_version",
    "kind",
    "paths"
  ],
  "additionalProperties": false
}
