{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deszo.local/schemas/grammar_feature_extractor/grammar_feature_config.v3.schema.json",
  "title": "Resolved ExtractorConfig and PagingConfig v3",
  "type": "object",
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion"
    },
    "include_diagnostics": {
      "type": "boolean",
      "default": true
    },
    "include_evidence": {
      "type": "boolean",
      "default": true
    },
    "include_construction_signatures": {
      "type": "boolean",
      "default": true
    },
    "include_contrastive_support": {
      "type": "boolean",
      "default": true
    },
    "enable_heuristics": {
      "type": "boolean",
      "default": true
    },
    "debug": {
      "type": "boolean",
      "default": false
    },
    "page_number": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "page_size": {
      "type": "integer",
      "minimum": 1,
      "default": 300
    },
    "limits": {
      "type": "object",
      "properties": {
        "max_input_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 104857600,
          "description": "Input file byte size before UTF-8 decoding."
        },
        "max_sentences": {
          "type": "integer",
          "minimum": 1,
          "default": 200000
        },
        "max_words_per_sentence": {
          "type": "integer",
          "minimum": 1,
          "default": 512
        },
        "max_total_words": {
          "type": "integer",
          "minimum": 1,
          "default": 5000000
        },
        "max_page_size": {
          "type": "integer",
          "minimum": 1,
          "default": 5000
        },
        "max_output_page_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 104857600,
          "description": "Canonical UTF-8 JSON byte size including final newline."
        },
        "max_output_pages": {
          "type": "integer",
          "minimum": 1,
          "default": 100000
        },
        "max_diagnostics_per_sentence": {
          "type": "integer",
          "minimum": 0,
          "default": 100,
          "description": "0 suppresses all diagnostics. If positive and exceeded, keep deterministic first max-1 diagnostics plus diagnostics_truncated summary diagnostic."
        }
      },
      "required": [
        "max_input_bytes",
        "max_sentences",
        "max_words_per_sentence",
        "max_total_words",
        "max_page_size",
        "max_output_page_bytes",
        "max_output_pages",
        "max_diagnostics_per_sentence"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "include_diagnostics",
    "include_evidence",
    "include_construction_signatures",
    "include_contrastive_support",
    "enable_heuristics",
    "debug",
    "page_number",
    "page_size",
    "limits"
  ],
  "additionalProperties": false,
  "$defs": {
    "SchemaVersion": {
      "const": "grammar_feature_extractor.v3"
    }
  },
  "description": "Schema for fully resolved config after defaults and explicit CLI/library overrides. Partial raw user config uses grammar_feature_config.input.v3.schema.json."
}
