{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deszo.local/schemas/grammar_feature_extractor/predicate_form_signature_registry.v5.schema.json",
  "title": "Predicate form signature registry v5 meta-schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "grammar_feature_extractor.v5"
    },
    "kind": {
      "const": "predicate_form_signature_registry"
    },
    "form_signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "signature": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "stable_since": {
            "type": "string",
            "minLength": 1
          },
          "deprecated_since": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          }
        },
        "required": [
          "signature",
          "stable_since"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema_version",
    "kind",
    "form_signatures"
  ],
  "additionalProperties": false
}
