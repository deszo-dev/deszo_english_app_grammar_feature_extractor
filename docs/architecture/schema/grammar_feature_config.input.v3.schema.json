{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deszo.local/schemas/grammar_feature_extractor/grammar_feature_config.input.v3.schema.json",
  "title": "Raw partial ExtractorConfig input v3",
  "description": "Optional raw user config schema for explicit config-file/API input. v3 CLI does not expose --config unless a versioned contract enables it.",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "grammar_feature_extractor.v3"
    },
    "include_diagnostics": {
      "type": "boolean"
    },
    "include_evidence": {
      "type": "boolean"
    },
    "include_construction_signatures": {
      "type": "boolean"
    },
    "include_contrastive_support": {
      "type": "boolean"
    },
    "enable_heuristics": {
      "type": "boolean"
    },
    "debug": {
      "type": "boolean"
    },
    "page_number": {
      "type": "integer",
      "minimum": 1
    },
    "page_size": {
      "type": "integer",
      "minimum": 1
    },
    "limits": {
      "type": "object",
      "properties": {
        "max_input_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "max_sentences": {
          "type": "integer",
          "minimum": 1
        },
        "max_words_per_sentence": {
          "type": "integer",
          "minimum": 1
        },
        "max_total_words": {
          "type": "integer",
          "minimum": 1
        },
        "max_page_size": {
          "type": "integer",
          "minimum": 1
        },
        "max_output_page_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "max_output_pages": {
          "type": "integer",
          "minimum": 1
        },
        "max_diagnostics_per_sentence": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
